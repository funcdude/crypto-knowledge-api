modules = ["python-3.12", "nodejs-20", "bash"]
[agent]
expertMode = true
integrations = ["python_database:1.0.0", "github:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["cargo", "libiconv", "libxcrypt", "postgresql", "redis", "rustc"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Start Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "redis-server --daemonize yes --logfile /tmp/redis.log && cd backend && uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3000
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 6379
externalPort = 3000

[[ports]]
localPort = 8000
externalPort = 8000

[userenv]

[userenv.shared]
REDIS_URL = "redis://localhost:6379/0"
PINECONE_INDEX_NAME = "crypto-knowledge"
PINECONE_ENVIRONMENT = "us-west1-gcp-free"
SKIP_PAYMENT_VERIFY = "true"
DEBUG = "true"
CORS_ORIGINS = "*"
PAYMENT_ADDRESS = "0x28e6b3e3e32308787f50e6d99e2b98745b381946"
X402_FACILITATOR_URL = "https://facilitator.coinbase.com"
SECRET_KEY = "dev-secret-key-change-in-production"

[deployment]
deploymentTarget = "vm"
run = ["bash", "start.sh"]
build = ["bash", "build.sh"]
