# Application Configuration
SECRET_KEY=your-secret-key-change-in-production
DEBUG=false
# Local dev only — never set to true in production
SKIP_PAYMENT_VERIFY=false
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# Book Configuration
BOOK_TITLE="Cryptocurrencies Decrypted: Hope and Economic Freedom for a Broken Financial System"
BOOK_AUTHOR="Oskar Hurme"
BOOK_AMAZON_URL="https://www.amazon.com/Cryptocurrencies-Decrypted-Economic-Freedom-Financial-ebook/dp/B0DQXC7XVJ"

# Pricing (in USD)
PRICE_SNIPPET=0.001
PRICE_EXPLANATION=0.005
PRICE_ANALYSIS=0.01
PRICE_CHAPTER_SUMMARY=0.02

# Performance Configuration
MAX_CHUNK_SIZE=1000
MAX_QUERY_LENGTH=500
CACHE_TTL=3600
RATE_LIMIT_PER_MINUTE=100

# Frontend (Next.js)
